{
  "id": "intro",
  "backgroundColor": "#000000",
  "grid": {
    "cols": 20,
    "rows": 10
  },
  "definitions": {
    "intro_sequence": [
      {
        "show": {
          "id": "dream-overlay",
          "texture": "scripts/dream.png",
          "layer": "overlay",
          "scaling": "fill",
          "effect": {
            "type": "fade-in",
            "seconds": 6,
            "blocking": false
          }
        }
      },
      {
        "playsound": {
          "id": "introbg",
          "path": "scripts/sounds/introbg.opus",
          "volume": 0.09,
          "fade": 1,
          "loop": true,
          "blocking": false
        }
      },
      {
        "say": "Do you wish to proceed?",
        "speaker": "GAME",
        "delay": 6
      },
      {
        "choice": {
          "prompt": "",
          "options": [
            {
              "text": "Yes.",
              "actions": [
                {
                  "say": "Understood. They will not act upon thee.",
                  "speaker": "GAME"
                },
                {
                  "choice": {
                    "prompt": "",
                    "options": [
                      {
                        "text": "I accept this arrangement.",
                        "actions": [
                          {
                            "say": "Understood. You may proceed.",
                            "speaker": "GAME"
                          },
                          {
                            "exit": true
                          }
                        ]
                      },
                      {
                        "text": "I do not accept this arrangement.",
                        "actions": [
                          {
                            "say": "Very well.",
                            "speaker": "GAME"
                          },
                          {
                            "goto": "ending"
                          }
                        ]
                      },
                      {
                        "text": "Why is that?",
                        "actions": [
                          {
                            "say": "...",
                            "speaker": "GAME"
                          },
                          {
                            "goto": "ending"
                          }
                        ]
                      }
                    ]
                  }
                }
              ]
            },
            {
              "text": "No.",
              "actions": [
                {
                  "say": "Do as you please.",
                  "speaker": "GAME"
                },
                {
                  "goto": "ending"
                }
              ]
            }
          ]
        }
      },
      {
        "hide": {
          "id": "dream-overlay",
          "effect": {
            "type": "fade-out",
            "seconds": 1,
            "blocking": true
          }
        }
      }
    ]
  },
  "hotspots": [],
  "onEnter": [
    {
      "run": "intro_sequence"
    },
    {
      "stopsound": {
        "id": "introbg",
        "fade": 1,
        "blocking": true
      }
    },
    {
      "goto": "abode"
    }
  ]
}