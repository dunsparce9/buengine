{
  "id": "abode",
  "background": "images/scenes/abode.jpg",
  "backgroundColor": "#000000",
  "grid": {
    "cols": 20,
    "rows": 10
  },
  "definitions": {
    "ladder_choice": [
      {
        "choice": {
          "prompt": "What do you do?",
          "options": [
            {
              "text": "Try to open it",
              "actions": [
                {
                  "say": "You push the hatch. It creaks open…",
                  "speaker": "Ominous voice"
                },
                {
                  "set": {
                    "clicked_ladder": true
                  }
                },
                {
                  "say": "Nothing interesting happens.",
                  "speaker": "Ominous voice"
                },
                {
                  "exit": true
                }
              ]
            },
            {
              "text": "Wait, you're not the narrator?",
              "actions": [
                {
                  "say": "*coughs* Ahem sorry",
                  "speaker": "Narrator"
                },
                {
                  "run": "ladder_choice"
                }
              ]
            },
            {
              "text": "Walk away",
              "actions": [
                {
                  "say": "You turn around. There's nowhere else to go.",
                  "speaker": "Narrator"
                },
                {
                  "exit": true
                }
              ]
            }
          ]
        }
      }
    ]
  },
  "objects": [
    {
      "id": "ladder",
      "label": "Mysterious ladder",
      "x": 12,
      "y": 5,
      "w": 5,
      "h": 4,
      "actions": [
        {
          "if": "abode.ladder.clicks >= 2",
          "then": [
            {
              "say": "Yep, ladder still there. What do?",
              "speaker": "Ominous voice"
            }
          ]
        },
        {
          "if": "abode.ladder.clicks == 1",
          "then": [
            {
              "say": "You find a huge mysterious ladder that probably leads somewhere.",
              "speaker": "Ominous voice"
            }
          ]
        },
        {
          "run": "ladder_choice"
        }
      ]
    },
    {
      "id": "spaghetti",
      "label": "Stale spaghetti",
      "x": 7,
      "y": 5,
      "w": 2,
      "h": 1,
      "actions": [
        {
          "say": "A disgusting(LY GOOD) plate of spaghetti and meatballs.",
          "speaker": "Narrator"
        },
        {
          "set": {
            "found_spaghetti": true
          }
        }
      ]
    },
    {
      "id": "beer",
      "label": "Mug of ber",
      "x": 9,
      "y": 4,
      "w": 1,
      "h": 1,
      "actions": [
        {
          "playsound": {
            "id": "beer",
            "path": "sounds/objects/clink.opus",
            "volume": 0.1,
            "loop": false,
            "blocking": false
          }
        },
        {
          "if": "abode.beer.clicks >= 5",
          "then": [
            {
              "say": "STOP. TOUCHING. THE BEER.",
              "speaker": "Narrator"
            }
          ]
        },
        {
          "if": "abode.beer.clicks == 4",
          "then": [
            {
              "say": "I swear, if you click on this one more time…",
              "speaker": "Narrator"
            }
          ]
        },
        {
          "if": "abode.beer.clicks == 3",
          "then": [
            {
              "say": "YES. It is STILL beer. What do you WANT from me?",
              "speaker": "Narrator"
            }
          ]
        },
        {
          "if": "abode.beer.clicks == 2",
          "then": [
            {
              "say": "It's beer. Again. You already looked at this.",
              "speaker": "Narrator"
            }
          ]
        },
        {
          "if": "abode.beer.clicks == 1",
          "then": [
            {
              "say": "It's beer.",
              "speaker": "Narrator"
            }
          ]
        }
      ]
    },
    {
      "id": "seal",
      "label": "Seal!",
      "texture": "images/seal.png",
      "x": 12,
      "y": 4,
      "w": 2,
      "h": 1,
      "actions": [
        {
          "playsound": {
            "id": "büe",
            "path": "sounds/objects/büe.opus",
            "volume": 0.1,
            "loop": false,
            "blocking": false
          }
        },
        {
          "say": "Büe...",
          "speaker": "Seal"
        },
        {
          "if": "abode.ladder.clicks >= 1",
          "then": [
            {
              "say": "The seal noticed your humble attempt at going down the ominous ladder.",
              "speaker": "Narrator"
            },
            {
              "say": "It lets out a curious and suggestive büe. You start feeling like you should check other parts of the room before going down.",
              "speaker": "Narrator"
            }
          ]
        },
        {
          "if": "abode.ladder.clicks == 0",
          "then": [
            {
              "say": "The cute seal pup bües at you, respectfully.",
              "speaker": "Narrator"
            }
          ]
        }
      ]
    }
  ],
  "onEnter": [
    {
      "effect": {
        "type": "fade-in",
        "seconds": 1,
        "blocking": false
      }
    },
    {
      "say": "You awaken in a humble abode. There's beer (ber!), and spaghetti with meatballs.",
      "speaker": "Narrator"
    }
  ]
}