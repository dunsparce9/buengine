{
  "id": "intro",
  "backgroundColor": "#000000",
  "grid": {
    "cols": 20,
    "rows": 10
  },
  "definitions": {
    "intro_sequence": [
      {
        "fork": {
          "run": "titlecards"
        }
      },
      {
        "playsound": {
          "id": "introbg",
          "path": "sounds/introbg.opus",
          "volume": 0.09,
          "fade": 1,
          "loop": true
        }
      },
      {
        "say": "SHALL IT COMMENCE?",
        "speaker": "GAME",
        "delay": 6
      },
      {
        "choice": {
          "options": [
            {
              "text": "Yes.",
              "actions": [
                {
                  "say": "IS IT AGREEABLE?",
                  "speaker": "GAME"
                },
                {
                  "choice": {
                    "prompt": "",
                    "options": [
                      {
                        "text": "It is.",
                        "actions": [
                          {
                            "say": "THEN, LET US SEIZE.",
                            "speaker": "GAME"
                          },
                          {
                            "stopsound": {
                              "id": "introbg",
                              "fade": 2,
                              "blocking": false
                            }
                          }
                        ]
                      },
                      {
                        "text": "It is not.",
                        "actions": [
                          {
                            "say": "THEN, THOU SHALT NOT.",
                            "speaker": "GAME"
                          },
                          {
                            "goto": "ending"
                          }
                        ]
                      },
                      {
                        "text": "What is?",
                        "actions": [
                          {
                            "say": "...",
                            "speaker": "GAME"
                          },
                          {
                            "goto": "ending"
                          }
                        ]
                      }
                    ]
                  }
                }
              ]
            },
            {
              "text": "No.",
              "actions": [
                {
                  "say": "THEN, IT SHALL NOT.",
                  "speaker": "GAME"
                },
                {
                  "goto": "ending"
                }
              ]
            }
          ]
        }
      }
    ],
