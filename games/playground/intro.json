{
  "id": "intro",
  "backgroundColor": "#000000",
  "grid": {
    "cols": 20,
    "rows": 10
  },
  "definitions": {
    "intro_sequence": [
      {
        "show": {
          "id": "dream-overlay",
          "texture": "dream.png",
          "layer": "overlay",
          "scaling": "fill",
          "effect": {
            "type": "fade-in",
            "seconds": 6,
            "blocking": false
          }
        }
      },
      {
        "playsound": {
          "id": "introbg",
          "path": "sounds/introbg.opus",
          "volume": 0.09,
          "fade": 1,
          "loop": true,
          "blocking": false
        }
      },
      {
        "say": "SHALL IT COMMENCE?",
        "speaker": "GAME",
        "delay": 6
      },
      {
        "choice": {
          "options": [
            {
              "text": "Yes.",
              "actions": [
                {
                  "say": "IS IT AGREEABLE?",
                  "speaker": "GAME"
                },
                {
                  "choice": {
                    "prompt": "",
                    "options": [
                      {
                        "text": "It is.",
                        "actions": [
                          {
                            "say": "THEN, LET US SEIZE.",
                            "speaker": "GAME"
                          },
                          {
                            "stopsound": {
                              "id": "introbg",
                              "fade": 2,
                              "blocking": false
                            }
                          }
                        ]
                      },
                      {
                        "text": "It is not.",
                        "actions": [
                          {
                            "say": "THEN, THOU SHALT NOT.",
                            "speaker": "GAME"
                          },
                          {
                            "goto": "ending"
                          }
                        ]
                      },
                      {
                        "text": "What is?",
                        "actions": [
                          {
                            "say": "...",
                            "speaker": "GAME"
                          },
                          {
                            "goto": "ending"
                          }
                        ]
                      }
                    ]
                  }
                }
              ]
            },
            {
              "text": "No.",
              "actions": [
                {
                  "say": "THEN, IT SHALL NOT.",
                  "speaker": "GAME"
                },
                {
                  "goto": "ending"
                }
              ]
            }
          ]
        }
      },
      {
        "hide": {
          "id": "dream-overlay",
          "effect": {
            "type": "fade-out",
            "seconds": 2,
            "blocking": true
          }
        }
      }
    ]
  },
  "objects": [],
  "onEnter": [
    {
      "run": "intro_sequence"
    },
    {
      "goto": "abode"
    }
  ]
}