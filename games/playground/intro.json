{
  "id": "intro",
  "backgroundColor": "#000000",
  "grid": {
    "cols": 20,
    "rows": 10
  },
  "definitions": {
    "intro_sequence": [
      {
        "fork": {
          "run": "titlecards"
        }
      },
      {
        "playsound": {
          "id": "introbg",
          "path": "sounds/introbg.opus",
          "volume": 0.09,
          "fade": 1,
          "loop": true
        }
      },
      {
        "say": "SHALL IT COMMENCE?",
        "speaker": "GAME",
        "delay": 6
      },
      {
        "choice": {
          "options": [
            {
              "text": "Yes.",
              "actions": [
                {
                  "say": "IS IT AGREEABLE?",
                  "speaker": "GAME"
                },
                {
                  "choice": {
                    "prompt": "",
                    "options": [
                      {
                        "text": "It is.",
                        "actions": [
                          {
                            "say": "THEN, LET US SEIZE.",
                            "speaker": "GAME"
                          },
                          {
                            "stopsound": {
                              "id": "introbg",
                              "fade": 2,
                              "blocking": false
                            }
                          }
                        ]
                      },
                      {
                        "text": "It is not.",
                        "actions": [
                          {
                            "say": "THEN, THOU SHALT NOT.",
                            "speaker": "GAME"
                          },
                          {
                            "goto": "ending"
                          }
                        ]
                      },
                      {
                        "text": "What is?",
                        "actions": [
                          {
                            "say": "...",
                            "speaker": "GAME"
                          },
                          {
                            "goto": "ending"
                          }
                        ]
                      }
                    ]
                  }
                }
              ]
            },
            {
              "text": "No.",
              "actions": [
                {
                  "say": "THEN, IT SHALL NOT.",
                  "speaker": "GAME"
                },
                {
                  "goto": "ending"
                }
              ]
            }
          ]
        }
      }
    ],
    "titlecards": [
      {
        "show": {
          "id": "dream-inter",
          "texture": "images/scenes/dream-inter.png",
          "layer": "overlay",
          "scaling": "fill",
          "effect": {
            "type": "fade-in",
            "seconds": 3,
            "blocking": true
          }
        }
      },
      {
        "loop": "true",
        "do": [
          {
            "text": {
              "id": "dream1",
              "text": "This game is for the faint-hearted",
              "position": {
                "anchor": "middle-center"
              },
              "fontSize": "24",
              "effect": {
                "type": "fade-in",
                "seconds": 3,
                "blocking": true
              }
            }
          },
          {
            "hide": {
              "id": "dream1",
              "effect": {
                "type": "fade-out",
                "seconds": 3,
                "blocking": true
              }
            }
          },
          {
            "text": {
              "id": "dream2",
              "position": {
                "anchor": "middle-center"
              },
              "fontSize": "24",
              "effect": {
                "type": "fade-in",
                "seconds": 3,
                "blocking": true
              },
              "text": "__Nothing__ you do __mattress__"
            }
          },
          {
            "hide": {
              "id": "dream2",
              "effect": {
                "type": "fade-out",
                "seconds": 3,
                "blocking": true
              }
            }
          },
          {
            "text": {
              "id": "dream3a",
              "position": {
                "anchor": "middle-center"
              },
              "fontSize": "24",
              "effect": {
                "type": "fade-in",
                "seconds": 4
              },
              "text": "The __numbers__ may even *change*",
              "color": "#ffa3a3"
            }
          },
          {
            "text": {
              "id": "dream3b",
              "position": {
                "anchor": "middle-center",
                "y": "10%"
              },
              "effect": {
                "type": "fade-in",
                "seconds": 4,
                "blocking": true
              },
              "text": "Lower numbers may result in suboptimal gameplay.",
              "color": "#bdbdbd",
              "fontSize": "12"
            }
          },
          {
            "wait": 1000
          },
          {
            "hide": {
              "id": "dream3a",
              "effect": {
                "type": "fade-out",
                "seconds": 3
              }
            }
          },
          {
            "hide": {
              "id": "dream3b",
              "effect": {
                "type": "fade-out",
                "seconds": 3,
                "blocking": true
              }
            }
          },
          {
            "text": {
              "id": "dream4",
              "position": {
                "anchor": "middle-center"
              },
              "fontSize": "36",
              "effect": {
                "type": "fade-in",
                "seconds": 3,
                "blocking": true
              },
              "text": "Sample Text",
              "color": "#FFFFFF"
            }
          },
          {
            "hide": {
              "id": "dream4",
              "effect": {
                "type": "fade-out",
                "seconds": 3,
                "blocking": true
              }
            }
          }
        ]
      }
    ]
  },
  "objects": [],
  "onEnter": [
    {
      "run": "intro_sequence"
    },
    {
      "effect": {
        "type": "fade-out",
        "seconds": 2,
        "blocking": true
      }
    },
    {
      "goto": "abode"
    }
  ]
}
